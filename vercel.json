{
  "crons": [
    {
      "path": "/api/cron/process",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/daily",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/monthly",
      "schedule": "0 8 1 * *"
    }
  ]
}
